<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Invoke_AccountRatingCalculator</name>
        <label>Invoke Account Rating Calculator</label>
        <locationX>176</locationX>
        <locationY>168</locationY>
        <actionName>AccountRatingCalculator</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>accountId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>AccountRatingCalculator</nameSegment>
    </actionCalls>
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Record-Triggered Flow that invokes AccountRatingCalculator whenever AnnualRevenue or NumberOfEmployees changes on an Account record.</description>
    <label>Account Rating Calculator</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>176</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Invoke_AccountRatingCalculator</targetReference>
        </connector>
        <filterFormula>ISCHANGED({!$Record.AnnualRevenue}) || ISCHANGED({!$Record.NumberOfEmployees})</filterFormula>
        <object>Account</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
