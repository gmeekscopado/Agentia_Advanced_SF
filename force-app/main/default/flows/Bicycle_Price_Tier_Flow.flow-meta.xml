        <label>Price Between $500 and $1,000?</label>
        <locationX>440</locationX>
        <locationY>134</locationY>
        <defaultConnector>
            <targetReference>Set_Tier_1</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No ($1,000+)</defaultConnectorLabel>
        <rules>
            <name>Price_Between_500_1000_Rule</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
