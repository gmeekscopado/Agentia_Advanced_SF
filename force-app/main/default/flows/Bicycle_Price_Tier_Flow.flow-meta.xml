<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Check_Price_Tier</name>
        <label>Check Price Tier</label>
        <locationX>176</locationX>
        <locationY>240</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Tier_1_Rule</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Price__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>1000.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tier_1</targetReference>
            </connector>
            <label>Price &gt;= 1000 (Tier 1)</label>
        </rules>
        <rules>
            <name>Tier_2_Rule</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Price__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>500.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tier_2</targetReference>
            </connector>
            <label>Price &gt;= 500 and less than 1000 (Tier 2)</label>
        </rules>
        <rules>
            <name>Tier_3_Rule</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Price__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>500.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tier_3</targetReference>
            </connector>
            <label>Price less than 500 (Tier 3)</label>
        </rules>
    </decisions>
    <description>Updates the Price Tier field on Bicycle__c based on the Price field. Triggers on record create and update.</description>
    <environments>Default</environments>
    <label>Bicycle Price Tier Flow</label>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Tier_1</name>
        <label>Set Tier 1</label>
        <locationX>0</locationX>
        <locationY>400</locationY>
        <inputAssignments>
            <field>Price_Tier__c</field>
            <value>
                <stringValue>Tier 1</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Set_Tier_2</name>
        <label>Set Tier 2</label>
        <locationX>176</locationX>
        <locationY>400</locationY>
        <inputAssignments>
            <field>Price_Tier__c</field>
            <value>
                <stringValue>Tier 2</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Set_Tier_3</name>
        <label>Set Tier 3</label>
        <locationX>352</locationX>
        <locationY>400</locationY>
        <inputAssignments>
            <field>Price_Tier__c</field>
            <value>
                <stringValue>Tier 3</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Check_Price_Tier</targetReference>
        </connector>
        <object>Bicycle__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
